# 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# 火山引擎 Seedream/Seedance API Key (用于AI生成商品视频)
# 获取地址: https://www.volcengine.com/
SEEDREAM_KEY=your_api_key_here

# TikTok Shop API 配置
# 在 TikTok Shop Partner 平台注册应用获取
NEXT_PUBLIC_TIKTOK_SHOP_APP_KEY=your_app_key_here
TIKTOK_SHOP_APP_SECRET=your_app_secret_here
NEXT_PUBLIC_TIKTOK_SHOP_CALLBACK_URL=http://localhost:3000/api/tiktok/auth/callback